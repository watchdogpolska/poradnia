msgid ""
"Enqueue attacment text extraction tasks for selected letters (20s apart)"
msgstr ""
"Zadania ekstrakcji tekstu z załączników dla wybranych listów (odstęp 20 "
"sekund)"

#: poradnia/letters/admin.py:134
