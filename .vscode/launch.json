        {
            "name": "Start Celery worker",
            "type": "debugpy",
            "request": "launch",
            "module": "celery",
            "args": [
                "-A",
                "config",
                "worker",
                "--pool=solo",
                // "--concurrency=1",
                "--loglevel=INFO",
            ],
            "django": true,
            "justMyCode": false,
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Start Celery beat",
            "type": "debugpy",
            "request": "launch",
            "module": "celery",
            "args": [
                "-A",
                "config",
                "beat",
                "--loglevel=INFO",
                "--logfile=${env:LOG_FILE_ENV}",
                "--scheduler=django_celery_beat.schedulers:DatabaseScheduler",
                "--pidfile="
            ],
            "django": true,
            "justMyCode": false,
            "cwd": "${workspaceFolder}"
        }
    ],
    "compounds": [
        {
            "name": "Django server + Celery worker + Celery beat",
            "configurations": [
                "Python: Django server 0.0.0.0:8000",
                "Start Celery worker",
                "Start Celery beat"
            ],
            "stopAll": true
        },
        {
            "name": "Run: Django shell + Celery Worker",
            "configurations": [
                "Python: Django shell", 
                "Start Celery worker",
            ],
            "stopAll": true
        },
        ]
